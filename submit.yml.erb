batch_connect:
  template: "basic"

script:
  job_name: "Blender_renderer"
  native:
    - "--nodes=<%= bc_num_slots %>"
    - "--ntasks=<%= bc_num_slots.to_i %>"
    - "--cpus-per-task=<%= num_cores %>"
    - "--mem=<%= num_memory %>G"
    - "--time=<%= bc_num_hours %>:00:00"
    - "-p <%= partition %>"
    - "--error=output.err"
<%
  selected_gpu = gpu_type.to_s.strip
  gres_name = selected_gpu.split('-', 2).first unless selected_gpu.empty? || selected_gpu == 'none'
%>
<% if gres_name %>
    - "--gres=gpu:<%= gres_name %>:1"
<% if selected_gpu.include?('-') %>
    - "--constraint=<%= selected_gpu %>"
<% end %>
<% end %>
