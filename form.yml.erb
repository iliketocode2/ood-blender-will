<%
  ERB.new(File.read(File.expand_path('partials/gpu_discovery.erb', __dir__))).result(binding)

  if (OodSupport::User.new.groups.map(&:name) & ['hpctools', 'blender']).any?
    max_slots = 6
  else
    max_slots = 1
  end
%>

---
cluster: "pax"

form:
  - bc_num_hours
  - num_cores
  - num_memory
  - partition
  - gpu_type
  - bc_num_slots
  - projectfile
  - outputdir
  - start_frame
  - end_frame

attributes:
<%= generate_partition_field.indent(2) %>
<%= generate_num_cores_field.indent(2) %>
<%= generate_num_memory_field.indent(2) %>
<%= generate_gpu_type_field.indent(2) %>
<%= generate_num_hours_field.indent(2) %>

  bc_num_slots:
    min: 1
    max: <%= max_slots %>

  projectfile:
    label: Blender Project File
    widget: path_selector
    directory: /cluster/tufts
    favorites:
      - /cluster/tufts
      - /cluster/home

  outputdir:
    label: "Render output directory"
    widget: path_selector
    directory: /cluster/home
    show_files: false
    help: "Specifies the output directory for storing your rendered frames. If left unset, it defaults to a output folder next to your selected project file."
    favorites:
      - /cluster/tufts
      - /cluster/home

  start_frame:
    label: "Start at frame number"
    help: "Enter the number of the frame to start at.  First frame is 1."
    value: "1"
    min: 1

  end_frame:
    label: "End at frame number"
    help: "Enter the number of the frame to end at.  Level blank to render to the last frame."
    value: ""
