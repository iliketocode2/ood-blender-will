<%
  @partition_filter = :gpu

  _partial_path = File.expand_path('dynamic_form_files/resource_discovery.erb', __dir__)
  _resource_result = ERB.new(File.read(_partial_path)).result(binding)

  if (OodSupport::User.new.groups.map(&:name) & ['hpctools', 'blender']).any?
    max_slots = 6
  else
    max_slots = 1
  end

  qos_options = (`sacctmgr show assoc where user=#{ENV['USER']} format=qos%1000 --noheader --parsable2 `).split(",")
  qos_default = "normal"
%>

---
cluster: "pax"
bc_dynamic_js: true

attributes:
<%= generate_partition_field.indent(2) %>
<%= generate_gpu_type_field.indent(2) %>
<%= generate_num_gpus_field.indent(2) %>
<%= generate_num_cores_field.indent(2) %>
<%= generate_num_memory_field.indent(2) %>
<%= generate_num_hours_field.indent(2) %>

  ta_qos:
    widget: "select"
    label: "Slurm QOS"
    options:
<% qos_options.each do |n| %>
    - ["<%= n %>", "<%= n %>"]
<% end %>  
    value: "<%=qos_default %>"

  bc_num_slots:
    min: 1
    max: <%=max_slots %>



  projectfile:
    label: Blender Project File
    widget: path_selector
    directory: /cluster/tufts
    favorites:
      - /cluster/tufts
      - /cluster/home

  outputdir:
    label: "Render output directory"
    widget: path_selector
    directory: /cluster/home
    show_files: false
    help: "Specifies the output directory for storing your rendered frames. If left unset, it defaults to a output folder next to your selected project file."
    favorites:
      - /cluster/tufts
      - /cluster/home

  start_frame:
    label: "Start at frame number"
    help: "Enter the number of the frame to start at.  First frame is 1."
    value: "1"
    min: 1

  end_frame:
    label: "End at frame number"
    help: "Enter the number of the frame to end at.  Level blank to render to the last frame."
    value: ""

form:
  - partition
  - gpu_type 
  - num_gpus
  - num_cores
  - num_memory
  - bc_num_hours
<%if qos_options.size > 1 %>
  - ta_qos
<%end%>
  - bc_num_slots
  - projectfile
  - outputdir
  - start_frame
  - end_frame
